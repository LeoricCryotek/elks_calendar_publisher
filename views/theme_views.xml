<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_elks_theme_list" model="ir.ui.view">
    <field name="name">elks.calendar.theme.list</field>
    <field name="model">elks.calendar.theme</field>
    <field name="arch" type="xml">
      <list string="Themes">
        <field name="name"/>
        <field name="code"/>
        <field name="applies_to_month"/>
        <field name="primary_color" widget="color"/>
        <field name="secondary_color" widget="color"/>
        <field name="is_stock" widget="boolean_toggle" readonly="1" string="Built-in"/>
      </list>
    </field>
  </record>

  <record id="view_elks_theme_form" model="ir.ui.view">
    <field name="name">elks.calendar.theme.form</field>
    <field name="model">elks.calendar.theme</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="code"/>
            <field name="applies_to_month"/>
            <field name="primary_color"/>
            <field name="secondary_color"/>
            <field name="header_font"/>
            <field name="decor_svg" filename="decor_filename"/>
            <field name="decor_filename" invisible="1"/>
            <field name="is_stock" readonly="1" string="Built-in"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_elks_themes" model="ir.actions.act_window">
    <field name="name">Themes</field>
    <field name="res_model">elks.calendar.theme</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
