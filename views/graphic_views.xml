<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_elks_graphic_list" model="ir.ui.view">
    <field name="name">elks.calendar.graphic.list</field>
    <field name="model">elks.calendar.graphic</field>
    <field name="arch" type="xml">
      <list string="Graphic Library">
        <field name="name"/>
        <field name="code"/>
        <field name="suggested_banner_style"/>
        <field name="is_stock" widget="boolean_toggle" readonly="1"/>
      </list>
    </field>
  </record>

  <record id="view_elks_graphic_form" model="ir.ui.view">
    <field name="name">elks.calendar.graphic.form</field>
    <field name="model">elks.calendar.graphic</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="code"/>
            <field name="suggested_banner_style"/>
            <field name="image" widget="image" filename="image_filename"/>
            <field name="image_filename" invisible="1"/>
            <field name="svg_inline" widget="ace" options="{'mode': 'xml'}"/>
            <field name="is_stock" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_elks_graphics" model="ir.actions.act_window">
    <field name="name">Graphic Library</field>
    <field name="res_model">elks.calendar.graphic</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_elks_graphics" name="Graphic Library"
            parent="menu_elks_calendar_root"
            action="action_elks_graphics" sequence="30"/>

</odoo>
