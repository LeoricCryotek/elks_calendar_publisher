<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_elks_banner_style_list" model="ir.ui.view">
    <field name="name">elks.calendar.banner.style.list</field>
    <field name="model">elks.calendar.banner.style</field>
    <field name="arch" type="xml">
      <list string="Banner Styles">
        <field name="sequence" widget="handle"/>
        <field name="name"/>
        <field name="code"/>
        <field name="description"/>
        <field name="color" widget="color"/>
        <field name="is_highlighted_box"/>
        <field name="is_italic"/>
        <field name="is_stock" widget="boolean_toggle" readonly="1" string="Built-in"/>
      </list>
    </field>
  </record>

  <record id="view_elks_banner_style_form" model="ir.ui.view">
    <field name="name">elks.calendar.banner.style.form</field>
    <field name="model">elks.calendar.banner.style</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="description" placeholder="e.g. red, centered"/>
              <field name="sequence"/>
              <field name="is_stock" readonly="1" string="Built-in"/>
            </group>
            <group string="Appearance">
              <field name="color" widget="color"/>
              <field name="is_highlighted_box"/>
              <field name="is_italic"/>
            </group>
          </group>
          <div class="alert alert-info" role="alert">
            <p>
              <strong>Banner styles</strong> give an event a visual treatment on the printed calendar and the website widget.
              Pick a colour for the headline text and, optionally, a highlighted-box or italic treatment.
            </p>
            <p>
              The <strong>code</strong> is used internally (CSS class suffix). Use lowercase and underscores only —
              e.g. <code>bingo_night</code>, <code>wedding</code>, <code>trivia</code>.
              Once an event references a style by code, don't rename the code — pick a new one for a new style instead.
            </p>
          </div>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_elks_banner_styles" model="ir.actions.act_window">
    <field name="name">Banner Styles</field>
    <field name="res_model">elks.calendar.banner.style</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Create a banner style</p>
      <p>
        Banner styles set the visual treatment for standout events on the printed
        monthly calendar and the public website widget. Give the style a name,
        pick a color, and events tagged with that style will render in that color.
      </p>
    </field>
  </record>

  <menuitem id="menu_elks_banner_styles" name="Banner Styles"
            parent="menu_elks_calendar_root"
            action="action_elks_banner_styles" sequence="40"/>

</odoo>
