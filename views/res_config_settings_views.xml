<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!--
    Inject an "Elks Calendar" block into the General Settings page so
    every lodge admin can pick their own timezone without touching code.
    Saving the form auto-writes the value to ir.config_parameter under
    key 'elks_calendar_publisher.lodge_tz' (the config_parameter
    attribute on the field handles that for us).
  -->
  <record id="res_config_settings_view_form_elks_calendar" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.elks.calendar</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//form" position="inside">
        <app string="Elks Calendar" name="elks_calendar_publisher"
             logo="/elks_calendar_publisher/static/description/icon.png">
          <block title="Lodge Setup"
                 help="Settings that apply to every printed calendar and the public website widget.">
            <setting string="Lodge Timezone"
                     help="Pick the timezone your lodge physically operates in. Every event time on the printed calendar PDF and on the public website widget will be displayed in this timezone, regardless of where a visitor is browsing from.">
              <field name="elks_calendar_lodge_tz"/>
            </setting>
          </block>
        </app>
      </xpath>
    </field>
  </record>

</odoo>
