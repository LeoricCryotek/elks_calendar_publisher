<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!--
    Two-template structure:

    * report_calendar_body  - the page body alone. Used by the in-form
      Live Preview and by the public website page (which is already
      wrapped in website.layout).

    * report_calendar_document - wraps the body in web.html_container so
      the PDF renderer gets a complete <!DOCTYPE html>...</html> document.

    LAYOUT NOTE — HTML tables, NOT CSS Grid:
    Odoo's PDF renderer uses wkhtmltopdf which is based on WebKit ~2013,
    long before CSS Grid was standardised. If the template uses
    `display: grid`, every cell falls back to block layout and the PDF
    is unreadable. This template uses real <table> markup so wkhtmltopdf
    and the browser both render the same 7-column layout.
  -->

  <!-- =================================================================
       Inner body — reusable fragment
       ================================================================= -->
  <template id="report_calendar_body">
    <div class="page">

          <style>
            .elks-cal { font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif; color: #1a1a1a; }

            /* Header row — three columns using a table so wkhtmltopdf can lay it out. */
            .elks-cal table.header-table { width: 100%; border: 0; padding: 0 6px 8px; }
            .elks-cal .month { font-size: 44px; font-weight: 800; letter-spacing: -1px; line-height: 1; text-align: left; width: 33%; }
            .elks-cal .deco  { font-size: 22px; letter-spacing: 4px; text-align: center; width: 34%; font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', 'Symbola', sans-serif; }
            .elks-cal .year  { font-size: 44px; font-weight: 800; letter-spacing: -1px; line-height: 1; text-align: right; width: 33%; }

            /* Grid + day row — one big table. */
            .elks-cal table.grid-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
            .elks-cal table.grid-table th { font-weight: 700; font-size: 14px; padding: 4px 0 6px; text-align: center; border: 0; }
            .elks-cal table.grid-table td.cell {
              border: 1px solid #1a1a1a;
              vertical-align: top;
              /* Cells auto-grow to fit content. height on a table cell
                 already behaves as min-height per CSS 2.1, so overflowing
                 days push the row taller instead of clipping. */
              height: 110px;
              padding: 4px 6px 6px;
              font-size: 11px;
              line-height: 1.25;
              position: relative;
              width: 14.28%;
              overflow: visible;
              word-wrap: break-word;
            }
            .elks-cal table.grid-table td.cell.blank { background: #f4f1eb; }

            .elks-cal .cell .num { font-size: 11px; font-weight: 700; color: #888; }
            .elks-cal .cell .holiday { position: absolute; top: 4px; left: 22px; right: 6px; text-align: center; font-size: 10px; font-style: italic; color: #b04a8a; font-weight: 600; line-height: 1.1; }

            .elks-cal .cell .banner { text-align: center; margin-top: 4px; }
            .elks-cal .cell .banner-graphic { display: inline-block; vertical-align: middle; line-height: 0; margin: -2px 3px 0 0; }
            .elks-cal .cell .banner-graphic svg { width: 16px; height: 16px; display: inline-block; vertical-align: middle; }
            .elks-cal .cell .banner-headline { font-weight: 800; font-size: 12px; line-height: 1.15; }
            .elks-cal .cell .banner-sub { font-size: 10px; font-weight: 600; margin-top: 1px; }
            .elks-cal .cell .event-time { font-weight: 700; color: #555; margin-right: 3px; }
            .elks-cal .cell .event-line { font-size: 10px; padding-left: 2px; margin-top: 1px; text-align: center; }

            .elks-cal .footer-note { margin-top: 6px; padding: 4px 0; font-size: 10px; color: #555; text-align: center; font-style: italic; }
          </style>

          <main class="elks-cal">

            <!-- Header — month | emoji strip | year in a single row -->
            <table class="header-table">
              <tr>
                <td class="month"><t t-esc="pub.month_label()"/></td>
                <td class="deco">
                  <t t-foreach="pub.month_emojis()" t-as="emoji">
                    <span t-esc="emoji"/>
                  </t>
                </td>
                <td class="year"><t t-esc="pub.year"/></td>
              </tr>
            </table>

            <!-- Day-of-week header + 6 rows of cells, all in one table so
                 wkhtmltopdf treats it as one continuous grid. -->
            <table class="grid-table">
              <thead>
                <tr>
                  <th>Sunday</th><th>Monday</th><th>Tuesday</th>
                  <th>Wednesday</th><th>Thursday</th><th>Friday</th>
                  <th>Saturday</th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="pub._get_grid_data()" t-as="week">
                  <tr>
                    <t t-foreach="week" t-as="cell">
                      <td t-attf-class="cell #{'blank' if cell['blank'] else ''}">
                        <t t-if="not cell['blank']">
                          <div class="num" t-esc="cell['day']"/>
                          <t t-set="holiday" t-value="pub.holiday_for_day(cell['day'])"/>
                          <t t-if="holiday">
                            <div class="holiday" t-esc="holiday"/>
                          </t>

                          <!-- Every event renders in its own chronological
                               slot. Banner-styled events (Karaoke, Queen of
                               Hearts, etc.) use their configured colour /
                               inline icon / box treatment but stay in time
                               order alongside standard events. -->
                          <t t-foreach="cell['events']" t-as="ev">
                            <t t-set="_is_banner" t-value="ev.is_banner()"/>
                            <t t-set="_box" t-value="_is_banner and ev.banner_is_box()"/>
                            <t t-set="_italic" t-value="_is_banner and ev.banner_is_italic()"/>
                            <t t-set="_color" t-value="ev.banner_color() if _is_banner else ''"/>
                            <t t-set="_time" t-value="ev.display_time()"/>

                            <div t-attf-class="event-line #{'banner-line' if _is_banner else ''}"
                                 t-attf-style="#{'background:#fff7e6;border:1px dashed #d49100;padding:3px;border-radius:4px;margin-top:2px;' if _box else ''}
                                               #{('color:' + _color + ';font-weight:800;') if _is_banner else ''}
                                               #{'font-style:italic;' if _italic else ''}">
                              <t t-if="_time">
                                <span t-attf-class="event-time"
                                      t-attf-style="#{('color:' + _color + ';') if _is_banner else ''}"
                                      t-esc="_time"/>
                              </t>
                              <!-- Icon priority (matches the dropdown display first):
                                   1. Emoji from the banner style's name (dropdown + calendar match exactly)
                                   2. Inline SVG from the linked graphic (advanced)
                                   3. Font Awesome icon from the linked graphic (advanced) -->
                              <t t-set="_symbol" t-value="ev.banner_symbol() if _is_banner else ''"/>
                              <t t-if="_symbol">
                                <span class="banner-symbol"
                                      style="margin-right: 3px; font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', 'Symbola', sans-serif;"
                                      t-esc="_symbol"/>
                              </t>
                              <t t-elif="_is_banner and ev.elks_use_graphic and ev.elks_graphic_id and ev.elks_graphic_id.svg_inline">
                                <span class="banner-graphic" t-out="ev.elks_graphic_id.svg_inline"/>
                              </t>
                              <t t-elif="_is_banner and ev.elks_use_graphic and ev.elks_graphic_id and ev.elks_graphic_id.fa_icon">
                                <i t-att-class="ev.elks_graphic_id.fa_icon_class()"
                                   t-attf-style="color: #{ev.elks_graphic_id.fa_color or '#c0392b'}; font-size: 12px; margin-right: 3px; vertical-align: middle;"/>
                              </t>
                              <span t-esc="ev.display_banner_label() if _is_banner else ev.name"/>
                              <t t-if="_is_banner and ev.elks_banner_sub">
                                <div class="banner-sub"
                                     t-attf-style="color: #{_color};"
                                     t-esc="ev.elks_banner_sub"/>
                              </t>
                            </div>
                          </t>
                        </t>
                      </td>
                    </t>
                  </tr>
                </t>
              </tbody>
            </table>

            <div class="footer-note" t-esc="pub.footer_text"/>
          </main>
        </div>
  </template>

  <!-- =================================================================
       Outer wrapper — only the PDF report uses this.
       Wraps the body in web.html_container so wkhtmltopdf gets a
       complete HTML document with doctype, html, and body.
       ================================================================= -->
  <template id="report_calendar_document">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="pub">
        <t t-call="elks_calendar_publisher.report_calendar_body"/>
      </t>
    </t>
  </template>
</odoo>
