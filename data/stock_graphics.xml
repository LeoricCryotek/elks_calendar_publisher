<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

  <record id="graphic_queen_hearts" model="elks.calendar.graphic">
    <field name="name">Queen of Hearts (heart + crown)</field>
    <field name="code">queen_hearts</field>
    <field name="suggested_banner_style">queen_hearts</field>
    <field name="is_stock">True</field>
    <field name="svg_inline"><![CDATA[
      <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <!-- heart -->
        <path d="M50 88 C 20 70, 8 50, 18 32 C 28 18, 44 22, 50 36
                 C 56 22, 72 18, 82 32 C 92 50, 80 70, 50 88 Z"
              fill="#c0392b"/>
        <!-- crown -->
        <path d="M28 28 L36 18 L44 26 L50 14 L56 26 L64 18 L72 28 Z"
              fill="#d4a017" stroke="#7a5c00" stroke-width="1.5"/>
      </svg>
    ]]></field>
  </record>

