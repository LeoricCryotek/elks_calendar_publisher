    <field name="code">loudmouth</field>
    <field name="suggested_banner_style">loudmouth</field>
    <field name="is_stock">True</field>
    <field name="svg_inline"><![CDATA[
      <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="40" fill="#c41e3a"/>
        <circle cx="50" cy="54" r="28" fill="#3a0008"/>
        <g fill="#ffffff">
          <rect x="30" y="29" width="7.5" height="13" rx="1.5"/>
          <rect x="38.5" y="27" width="7.5" height="15" rx="1.5"/>
          <rect x="47" y="27" width="7.5" height="15" rx="1.5"/>
          <rect x="55.5" y="27" width="7.5" height="15" rx="1.5"/>
          <rect x="64" y="29" width="7.5" height="13" rx="1.5"/>
        </g>
        <path d="M 33 58 Q 50 95 67 58 Q 59 67 50 65 Q 41 67 33 58 Z"
              fill="#ff667a"/>
        <line x1="50" y1="66" x2="50" y2="86" stroke="#a83050"
              stroke-width="1.6" opacity="0.55"/>
      </svg>
    ]]></field>
  </record>

