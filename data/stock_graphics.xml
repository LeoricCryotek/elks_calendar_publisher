        <circle cx="50" cy="50" r="42" fill="#1f6f4a"/>
        <circle cx="50" cy="50" r="26" fill="#fff"/>
        <text x="50" y="58" text-anchor="middle"
              font-family="Helvetica,Arial,sans-serif"
              font-size="22" font-weight="800" fill="#1f6f4a">B</text>
      </svg>
    ]]></field>
  </record>

